# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/astronaut

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# .NET Analyzer
DOTNET_ANALYZER_PATH=./analyzer/bin/Release/net8.0/ASTronautAnalyzer.dll

# Limits
MAX_CONCURRENT_ANALYSES=3
RATE_LIMIT_PER_HOUR=10

# Timeouts (ms)
CLONE_TIMEOUT_MS=30000
RESTORE_TIMEOUT_MS=60000
PARSE_TIMEOUT_MS=60000
PR_TIMEOUT_MS=15000

# Logging
LOG_LEVEL=info
