# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/astronaut
DB_POOL_MAX=10

# GitHub App
GITHUB_APP_ID=CHANGE_ME
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# .NET Analyzer
DOTNET_ANALYZER_PATH=./analyzers/dotnet/bin/Release/net8.0/ASTronautAnalyzer.dll

# Go Analyzer (Gin)
GIN_ANALYZER_PATH=./analyzers/gin/bin/gin-analyzer

# Limits
MAX_CONCURRENT_ANALYSES=3
RATE_LIMIT_PER_HOUR=10
MAX_QUEUE_SIZE=100

# Timeouts (ms)
CLONE_TIMEOUT_MS=90000
RESTORE_TIMEOUT_MS=120000
PARSE_TIMEOUT_MS=120000
PR_TIMEOUT_MS=30000
JOB_TIMEOUT_MS=600000

# Logging
LOG_LEVEL=info
