{
  "name": "astronaut-v2",
  "version": "0.0.0",
  "private": true,
  "description": "ASTronaut v2 — CLI-first OpenAPI generator from source code (pure AST)",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./apps/*\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "gen:proto": "pnpm --filter @astronaut/core gen:proto",
    "build:analyzers": "bash scripts/build-analyzers.sh",
    "cli": "pnpm --filter @astronaut/cli dev",
    "clean": "pnpm -r exec rimraf dist coverage .tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
