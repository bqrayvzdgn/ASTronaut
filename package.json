{
  "name": "astronaut",
  "version": "1.0.0",
  "description": "Automatically generate OpenAPI documentation from source code after every successful deploy",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push"
  },
  "dependencies": {
    "express": "^4.21.0",
    "@octokit/app": "^15.1.0",
    "@octokit/rest": "^21.0.0",
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "ts-morph": "^24.0.0",
    "drizzle-orm": "^0.33.0",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "js-yaml": "^4.1.0",
    "dotenv": "^16.4.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/babel__traverse": "^7.20.0",
    "drizzle-kit": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "pino-pretty": "^11.2.0",
    "ts-node": "^10.9.0"
  }
}
